{
  "manifest_version": 3,
  "name": "Google Form Auto-filler",
  "version": "1.0",
  "description": "Automatically fill Google Forms with preset answers.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://docs.google.com/forms/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Auto-filler settings",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://docs.google.com/forms/*"],
      "js": ["handlers.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
